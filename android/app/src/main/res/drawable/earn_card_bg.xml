<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gold border -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFD54F"
                android:centerColor="#FFFFAB00"
                android:endColor="#FFFFA000"
                android:angle="135" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Inner dark blue card -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF1A1A3E"
                android:centerColor="#FF252560"
                android:endColor="#FF1E1E4A"
                android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
