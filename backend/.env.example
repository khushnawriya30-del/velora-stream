# CineVault Backend Environment Configuration
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cinevault

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRY=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# AWS S3 / Cloudflare R2
S3_BUCKET=cinevault-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_ENDPOINT=https://s3.amazonaws.com
CDN_BASE_URL=https://cdn.cine


vault.app

# Video URL Signing
VIDEO_SIGN_SECRET=your-video-signing-secret
VIDEO_URL_EXPIRY=3600

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:3001
